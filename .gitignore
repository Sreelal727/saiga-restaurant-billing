# Dependencies
node_modules/
**/node_modules/

# Environment — NEVER commit real secrets
.env
.env.local
.env.production
.env*.local

# Next.js build output
.next/
out/

# Playwright
test-results/
playwright-report/
playwright/.cache/

# Convex compiled output (regenerated at build time via `convex deploy`)
# Note: _generated/ is committed so Vercel always has types available during `next build`
convex/*.js
convex/*.js.map

# SQLite database files
*.db
*.db-journal
*.db-wal
*.db-shm

# Build output
dist/
build/
.vite/

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# pnpm
.pnpm-store/

.vercel

# TypeScript incremental build info
tsconfig.tsbuildinfo

# Next.js auto-generated env reference
next-env.d.ts

# Convex migration artifacts (secrets + data — never commit)
.migration/
.env.migrate
